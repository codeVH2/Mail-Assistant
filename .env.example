# Database
POSTGRES_USER=mail_assistant
POSTGRES_PASSWORD=mail_assistant
POSTGRES_DB=mail_assistant
DATABASE_URL=postgresql+psycopg://mail_assistant:mail_assistant@localhost:5432/mail_assistant

# AI provider: "local" (Ollama) or "cloud" (Anthropic)
AI_PROVIDER=local

# Ollama (used when AI_PROVIDER=local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Anthropic (used when AI_PROVIDER=cloud — evaluation only)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Gmail OAuth 2.0
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# App
SECRET_KEY=change-me-in-production
DEBUG=true
